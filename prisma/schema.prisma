
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}


// --------- 1. ROOM CATEGORY ------------
model Room {
  id          String   @id @default(uuid())
  name        String
  type        String
  price       Float
  image       String?
  description String?
  amenities   String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  units        RoomUnit[]   //One Room Category can have many physical Room Units
}

// ------------2. ROOM UNTS-----------------

enum RoomStatus {
  AVAILABLE
  BOOKED
  OCCUPIED
  MAINTENANCE
}

model RoomUnit {
  id          String   @id @default(uuid())
  roomNumber  String   @unique
  status      RoomStatus   @default(AVAILABLE)   // AVAILABLE / BOOKED / OCCUPIED / MAINTENANCE

  //Relation : Each unit belongs to a specific Room Category
  roomId      String
  room        Room     @relation(fields: [roomId], references: [id], onDelete: Cascade) 

  bookings    Booking[] // A single physical room can have a history of many bookings

  createdAt   DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}


// -------------3.  BOOKING TRANSACTION ------------
model Booking {
  id            String    @id @default(uuid())
  guestName     String
  email         String
  phone         String
  checkInDate   DateTime
  checkOutDate  DateTime
  specialReq    String?
  
  //  We save the total price here so if the hotel changes 
  // their prices, old receip dont change.
  totalPrice    Float     

  // The Relation: This booking reserves a specific physical room
  roomUnitId    String
  roomUnit      RoomUnit  @relation(fields: [roomUnitId], references: [id], onDelete: Restrict)

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

enum Role {
  MANAGER 
  RECEPTIONIST
}

model Staff {
  // This ID will exactly match the secure UUID generated by Supabase Auth
  id        String   @id 
  email     String   @unique
  name      String
  role      Role     @default(RECEPTIONIST)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}