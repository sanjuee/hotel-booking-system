
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Room {
  id          String   @id @default(uuid())
  name        String
  type        String
  price       Float
  image       String?
  description String?
  amenities   String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
